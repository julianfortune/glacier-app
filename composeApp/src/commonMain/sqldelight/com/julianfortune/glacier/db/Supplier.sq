CREATE TABLE IF NOT EXISTS Supplier (
    id INTEGER PRIMARY KEY,
    name TEXT NOT NULL UNIQUE
);

-- QUERIES
getAll:
SELECT * FROM Supplier ORDER BY name ASC;

getById:
SELECT * FROM Supplier WHERE id = :id LIMIT 1;

deleteById:
DELETE FROM Supplier WHERE id = :id;

deleteAll:
DELETE FROM Supplier;

insert:
INSERT INTO Supplier (name) VALUES (:name) RETURNING id;

updateById:
UPDATE Supplier
SET name = :name
WHERE id = :id;
